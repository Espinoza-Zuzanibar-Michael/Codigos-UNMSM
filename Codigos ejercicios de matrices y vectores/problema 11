#include <iostream>
using namespace std;

const int MAX_COLS = 10;

int sumarDiagonalPrincipal(int matriz[][MAX_COLS], int m, int n) {
    int suma = 0;
    
    for (int i = 0; i < m && i < n; i++) {
        suma += matriz[i][i];
    }
    
    return suma;
}

int main() {
    int m = 3;
    int n = 3;
    int miMatriz[3][MAX_COLS] = {
        {1, 2, 3},
        {4, 5, 6},
        {7, 8, 9}
    };
    
    cout << "La suma de la diagonal de izquierda a derecha es: " << sumarDiagonalPrincipal(miMatriz, m, n) << endl;
    
    return 0;
}
