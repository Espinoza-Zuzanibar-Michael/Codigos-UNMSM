#include <iostream>
using namespace std;

double minimoVector(double v[], int n) {
    double min = v[0];
    
    for (int i = 1; i < n; i++) {
        if (v[i] < min) {
            min = v[i];
        }
    }
    
    return min;
}

int main() {
    int n = 5;
    double miVector[5] = {15.5, 8.2, 3.1, 20.0, 5.0};
    
    cout << "El minimo es: " << minimoVector(miVector, n) << endl;
    
    return 0;
}
