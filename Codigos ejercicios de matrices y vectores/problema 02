#include <iostream>
using namespace std;

double sumaAlCuadrado(double v[], int n) {
    double suma = 0;
    
    for (int i = 0; i < n; i++) {
        suma += (v[i] * v[i]); 
    }
    
    return suma;
}

int main() {
    int n = 4;
    double miVector[4] = {2.0, 3.0, 4.0, 1.0};
    
    double resultado = sumaAlCuadrado(miVector, n);
    cout << "La suma de los cuadrados es: " << resultado << endl;
    
    return 0;
}
