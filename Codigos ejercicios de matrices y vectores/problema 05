#include <iostream>
using namespace std;

void sumarNumeroAVector(double v[], double numero, double resultado[], int n) {
    for (int i = 0; i < n; i++) {
        resultado[i] = v[i] + numero;
    }
}

int main() {
    int n = 3;
    double numeroSumar = 10.5;
    double miVector[3] = {2.0, 4.5, -1.0};
    double vectorResultado[3];
    
    sumarNumeroAVector(miVector, numeroSumar, vectorResultado, n);
    
    cout << "El vector resultante de la suma es: ";
    for (int i = 0; i < n; i++) {
        cout << vectorResultado[i] << " ";
    }
    cout << endl;
    
    return 0;
}
