#include <iostream>
using namespace std;

double productoEscalar(double v[], double w[], int n) {
    double productoTotal = 0;
    
    for (int i = 0; i < n; i++) {
        productoTotal += (v[i] * w[i]);
    }
    
    return productoTotal;
}

int main() {
    int n = 3;
    double vectorV[3] = {1.0, 2.0, 3.0};
    double vectorW[3] = {4.0, 5.0, 6.0};
    
    double resultado = productoEscalar(vectorV, vectorW, n);
    cout << "El producto escalar es: " << resultado << endl;
    
    return 0;
}
