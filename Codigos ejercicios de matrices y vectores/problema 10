#include <iostream>
using namespace std;

const int MAX_COLS = 10;

void sumarColumnas(int matriz[][MAX_COLS], int m, int n) {
    for (int j = 0; j < n; j++) {
        int sumaColumna = 0;
        
        for (int i = 0; i < m; i++) {
            sumaColumna += matriz[i][j];
        }
        
        cout << "La suma de la columna " << j << " es: " << sumaColumna << endl;
    }
}

int main() {
    int m = 3;
    int n = 3;
    int miMatriz[3][MAX_COLS] = {
        {1, 2, 3},
        {4, 5, 6},
        {7, 8, 9}
    };
    
    sumarColumnas(miMatriz, m, n);
    
    return 0;
}
